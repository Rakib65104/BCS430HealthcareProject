<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="720.0"
            prefWidth="1180.0"
            stylesheets="@doctor-schedule.css"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="rakib.bcs430healthcareproject.ScheduleController">

    <top>
        <VBox spacing="0">
            <HBox style="-fx-background-color: #0F766E; -fx-padding: 18 24; -fx-alignment: center-left; -fx-spacing: 14;">
                <Label text="HealthConnect"
                       style="-fx-text-fill: white; -fx-font-size: 22; -fx-font-weight: bold;" />

                <Region HBox.hgrow="ALWAYS" />

                <Label fx:id="doctorNameLabel"
                       style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;" />
            </HBox>

            <HBox style="-fx-background-color: #F0FDFA; -fx-padding: 12 24; -fx-spacing: 10; -fx-border-color: #D1FAE5; -fx-border-width: 0 0 1 0;">
                <Button mnemonicParsing="false"
                        onAction="#onBackToDashboard"
                        style="-fx-background-color: white; -fx-text-fill: #0F766E; -fx-font-size: 13; -fx-font-weight: bold; -fx-border-color: #14B8A6; -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 10 18;"
                        text="Dashboard" />

                <Button mnemonicParsing="false"
                        style="-fx-background-color: #0F766E; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 10 18;"
                        text="Schedule Management" />

                <Button fx:id="btnReschedule"
                        mnemonicParsing="false"
                        onAction="#handleReschedule"
                        style="-fx-background-color: white; -fx-text-fill: #0F766E; -fx-font-size: 13; -fx-font-weight: bold; -fx-border-color: #14B8A6; -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 10 18;"
                        text="Reschedule" />
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="18.0" style="-fx-background-color: #F8FAFC;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>

            <children>
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <VBox spacing="4.0">
                            <children>
                                <Label text="Daily Schedule" textFill="#0F172A">
                                    <font>
                                        <Font name="Segoe UI Bold" size="24.0" />
                                    </font>
                                </Label>
                                <Label text="Doctor-side appointment management" textFill="#64748B" />
                            </children>
                        </VBox>

                        <Separator orientation="VERTICAL" prefHeight="48.0" />

                        <Label text="Date:" />
                        <DatePicker fx:id="scheduleDatePicker" promptText="Select Date" />
                    </children>
                </HBox>

                <Label fx:id="statusLabel" style="-fx-text-fill: #0F766E; -fx-font-size: 12; -fx-font-weight: bold;" text="Loading schedule..." />

                <TableView fx:id="appointmentTable" prefHeight="600.0" prefWidth="780.0" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colTime" prefWidth="100.0" text="Time" />
                        <TableColumn fx:id="colPatient" prefWidth="180.0" text="Patient Name" />
                        <TableColumn fx:id="colType" prefWidth="140.0" text="Type" />
                        <TableColumn fx:id="colStatus" prefWidth="110.0" text="Status" />
                        <TableColumn fx:id="colNotes" prefWidth="260.0" text="Notes" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <children>
                        <Button fx:id="btnMessage"
                                mnemonicParsing="false"
                                onAction="#handleMessagePatient"
                                style="-fx-background-color: #F59E0B; -fx-text-fill: white; -fx-font-weight: bold;"
                                text="Message Patient" />
                        <Button fx:id="btnPrescription"
                                mnemonicParsing="false"
                                onAction="#handleSendPrescription"
                                style="-fx-background-color: #7C3AED; -fx-text-fill: white; -fx-font-weight: bold;"
                                text="Send Prescription" />
                        <Button mnemonicParsing="false"
                                onAction="#handleCancelSelected"
                                style="-fx-background-color: #DC2626; -fx-text-fill: white; -fx-font-weight: bold;"
                                text="Cancel Selected" />
                        <Button mnemonicParsing="false"
                                onAction="#handleMarkComplete"
                                style="-fx-background-color: #16A34A; -fx-text-fill: white; -fx-font-weight: bold;"
                                text="Mark as Complete" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>

    <right>
        <VBox prefWidth="300.0" spacing="15.0" style="-fx-background-color: white; -fx-border-color: #CBD5E1; -fx-border-width: 0 0 0 1;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>

            <children>
                <Label text="New Schedule" textFill="#0F172A">
                    <font>
                        <Font name="Segoe UI Bold" size="18.0" />
                    </font>
                </Label>

                <Label text="Patient Name" textFill="#64748B" />
                <TextField fx:id="txtName" promptText="Enter full name" />

                <Label text="Contact Number" textFill="#64748B" />
                <TextField fx:id="txtContact" promptText="(555) 000-0000" />

                <HBox spacing="10.0">
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label text="Time" textFill="#64748B" />
                                <ComboBox fx:id="comboTime" editable="true" prefWidth="130.0" promptText="09:00 AM" />
                            </children>
                        </VBox>
                        <VBox spacing="5.0">
                            <children>
                                <Label text="Duration" textFill="#64748B" />
                                <ComboBox fx:id="comboDuration" prefWidth="130.0" promptText="30 min" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <Label text="Schedule Type" textFill="#64748B" />
                <ComboBox fx:id="comboType" maxWidth="1.7976931348623157E308" promptText="Check-up" />

                <Label text="Reason / Notes" textFill="#64748B" />
                <TextArea fx:id="txtReason" prefHeight="110.0" promptText="Brief description..." wrapText="true" />

                <Separator />

                <Button fx:id="btnBookSchedule"
                        maxWidth="1.7976931348623157E308"
                        mnemonicParsing="false"
                        onAction="#handleBookAppointment"
                        prefHeight="40.0"
                        style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-font-weight: bold;"
                        text="Book Schedule" />
            </children>
        </VBox>
    </right>
</BorderPane>
