<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="rakib.bcs430healthcareproject.LoginController"
            stylesheets="@app.css"
            style="-fx-background-color: linear-gradient(to bottom right, #D1FAE5, #ECFEFF, #F8FAFC);">

    <top>
        <HBox style="-fx-background-color: linear-gradient(to right, #0F766E, #14B8A6);
                     -fx-padding: 18 24;
                     -fx-alignment: center-left;">
            <Label text="HealthConnect"
                   style="-fx-text-fill:white; -fx-font-size:22; -fx-font-weight:bold;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="Patient and Doctor Portal"
                   style="-fx-text-fill:#CCFBF1; -fx-font-size:14;"/>
        </HBox>
    </top>

    <center>
        <StackPane style="-fx-padding: 36;">
            <VBox spacing="15"
                  maxWidth="430"
                  alignment="CENTER_LEFT"
                  style="-fx-background-color: white;
                         -fx-background-radius: 18;
                         -fx-padding: 30;
                         -fx-border-color: #CCFBF1;
                         -fx-border-radius: 18;
                         -fx-effect: dropshadow(gaussian, rgba(15,118,110,0.24), 28, 0.18, 0, 10);">

                <VBox spacing="4" alignment="CENTER_LEFT">
                    <Label text="Welcome"
                           style="-fx-font-size:24; -fx-font-weight:bold; -fx-text-fill:#134E4A;"/>

                    <Label text="Log in to your account"
                           style="-fx-font-size:13; -fx-text-fill:#64748B;"/>
                </VBox>

                <VBox spacing="7" maxWidth="1.7976931348623157E308">
                    <Label text="Email (Username)"
                           style="-fx-font-size:13; -fx-font-weight:bold; -fx-text-fill:#334155;"/>

                    <TextField fx:id="emailField"
                               promptText="name@example.com"
                               maxWidth="1.7976931348623157E308"
                               style="-fx-background-radius:10; -fx-border-radius:10; -fx-padding:10;"/>
                </VBox>

                <VBox spacing="7" maxWidth="1.7976931348623157E308">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Password"
                               style="-fx-font-size:13; -fx-font-weight:bold; -fx-text-fill:#334155;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Hyperlink text="Forgot password?"
                                   onAction="#onForgotPassword"
                                   style="-fx-font-size:12; -fx-text-fill:#0F766E; -fx-padding:0; -fx-border-width:0;"/>
                    </HBox>

                    <PasswordField fx:id="passwordField"
                                   promptText="••••••••"
                                   maxWidth="1.7976931348623157E308"
                                   style="-fx-background-radius:10; -fx-border-radius:10; -fx-padding:10;"/>
                </VBox>

                <Label fx:id="errorLabel"
                       text=""
                       managed="false"
                       visible="false"
                       wrapText="true"
                       style="-fx-text-fill:#DC2626; -fx-font-size:12;"/>

                <Button text="Log In"
                        onAction="#onLogin"
                        maxWidth="1.7976931348623157E308"
                        style="-fx-background-color: linear-gradient(to right, #0F766E, #14B8A6);
                               -fx-text-fill:white;
                               -fx-font-weight:bold;
                               -fx-background-radius:10;
                               -fx-padding:11 16;"/>

                <HBox spacing="6" alignment="CENTER" maxWidth="1.7976931348623157E308">
                    <Label text="No account?"
                           style="-fx-text-fill:#64748B;"/>

                    <Hyperlink text="Create one"
                               onAction="#onGoSignup"
                               style="-fx-text-fill:#0F766E; -fx-font-weight:bold; -fx-border-width:0;"/>
                </HBox>

                <HBox spacing="10" alignment="CENTER" maxWidth="1.7976931348623157E308">
                    <Button text="Hospital Portal"
                            onAction="#onHospitalPortal"
                            HBox.hgrow="ALWAYS"
                            maxWidth="1.7976931348623157E308"
                            style="-fx-background-color:#E6FFFA;
                                   -fx-text-fill:#0F766E;
                                   -fx-font-weight:bold;
                                   -fx-border-color:#99F6E4;
                                   -fx-border-radius:10;
                                   -fx-background-radius:10;
                                   -fx-padding:10 14;"/>

                    <Button text="Pharmacy Portal"
                            onAction="#onPharmacyPortal"
                            HBox.hgrow="ALWAYS"
                            maxWidth="1.7976931348623157E308"
                            style="-fx-background-color:#E6FFFA;
                                   -fx-text-fill:#0F766E;
                                   -fx-font-weight:bold;
                                   -fx-border-color:#99F6E4;
                                   -fx-border-radius:10;
                                   -fx-background-radius:10;
                                   -fx-padding:10 14;"/>
                </HBox>

            </VBox>
        </StackPane>
    </center>

</BorderPane>