<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="rakib.bcs430healthcareproject.HospitalDiagnosticController"
            stylesheets="@app.css"
            styleClass="root">

    <top>
        <VBox spacing="0">
            <HBox style="-fx-background-color: #0F766E; -fx-padding: 16 24; -fx-alignment: center-left; -fx-spacing: 18;">
                <Button text="← Back"
                        onAction="#onBack"
                        style="-fx-background-color: white; -fx-text-fill: #0F766E; -fx-font-size: 12; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 6 14; -fx-cursor: hand;" />

                <Label text="HealthConnect"
                       style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;" />

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="Refresh"
                        onAction="#onRefresh"
                        style="-fx-background-color: #14B8A6; -fx-text-fill: white; -fx-font-size: 12; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 6 14; -fx-cursor: hand;" />
            </HBox>

            <HBox style="-fx-background-color: #134E4A; -fx-padding: 18 24;">
                <VBox spacing="4">
                    <Label text="Upload Diagnostic Results"
                           style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;" />
                    <Label fx:id="hospitalNameLabel"
                           text="Hospital"
                           style="-fx-text-fill: #CCFBF1; -fx-font-size: 13;" />
                </VBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <content>
                <VBox spacing="18" style="-fx-padding: 20; -fx-background-color: #F8FAFC;">

                    <VBox styleClass="card" spacing="12" style="-fx-padding:18;">
                        <Label text="Select Scheduled Appointment"
                               style="-fx-text-fill:#0F766E; -fx-font-size:18; -fx-font-weight:bold;" />

                        <ComboBox fx:id="appointmentComboBox"
                                  prefWidth="850"
                                  style="-fx-font-size:13;" />

                        <Label fx:id="statusLabel"
                               text="Select an appointment to upload diagnostic results."
                               style="-fx-text-fill:#475569; -fx-font-size:12;" />
                    </VBox>

                    <VBox fx:id="appointmentPreviewBox" styleClass="card" spacing="12" style="-fx-padding:18;">
                        <Label text="Appointment Preview"
                               style="-fx-text-fill:#0F766E; -fx-font-size:18; -fx-font-weight:bold;" />

                        <HBox spacing="20">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="Patient"
                                       style="-fx-text-fill:#64748B; -fx-font-size:12; -fx-font-weight:bold;" />
                                <Label fx:id="patientNameLabel"
                                       text="No appointment selected"
                                       style="-fx-text-fill:#0F766E; -fx-font-size:14; -fx-font-weight:bold;" />
                            </VBox>

                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="Doctor"
                                       style="-fx-text-fill:#64748B; -fx-font-size:12; -fx-font-weight:bold;" />
                                <Label fx:id="doctorNameLabel"
                                       text="No appointment selected"
                                       style="-fx-text-fill:#0F766E; -fx-font-size:14; -fx-font-weight:bold;" />
                            </VBox>
                        </HBox>

                        <HBox spacing="20">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="Appointment Date"
                                       style="-fx-text-fill:#64748B; -fx-font-size:12; -fx-font-weight:bold;" />
                                <Label fx:id="appointmentDateLabel"
                                       text="No appointment selected"
                                       style="-fx-text-fill:#334155; -fx-font-size:13;" />
                            </VBox>

                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="Reason"
                                       style="-fx-text-fill:#64748B; -fx-font-size:12; -fx-font-weight:bold;" />
                                <Label fx:id="reasonLabel"
                                       text="No appointment selected"
                                       style="-fx-text-fill:#334155; -fx-font-size:13;" />
                            </VBox>
                        </HBox>
                    </VBox>

                    <VBox styleClass="card" spacing="12" style="-fx-padding:18;">
                        <Label text="Report Title"
                               style="-fx-text-fill:#0F766E; -fx-font-size:17; -fx-font-weight:bold;" />

                        <TextField fx:id="reportTitleField"
                                   promptText="Example: Chest CT Scan Report / Blood Panel Review"
                                   style="-fx-font-size:13;" />

                        <Label text="Report Type"
                               style="-fx-text-fill:#0F766E; -fx-font-size:17; -fx-font-weight:bold;" />

                        <ComboBox fx:id="reportTypeComboBox"
                                  prefWidth="400"
                                  style="-fx-font-size:13;" />
                    </VBox>

                    <VBox styleClass="card" spacing="12" style="-fx-padding:18;">
                        <Label text="Hospital Findings"
                               style="-fx-text-fill:#0F766E; -fx-font-size:17; -fx-font-weight:bold;" />

                        <TextArea fx:id="hospitalFindingsTextArea"
                                  prefHeight="130"
                                  wrapText="true"
                                  promptText="Enter physician observations, imaging findings, notes, clinical findings..."
                                  style="-fx-font-size:13;" />
                    </VBox>

                    <VBox styleClass="card" spacing="12" style="-fx-padding:18;">
                        <Label text="Diagnostic Results"
                               style="-fx-text-fill:#0F766E; -fx-font-size:17; -fx-font-weight:bold;" />

                        <TextArea fx:id="diagnosticResultsTextArea"
                                  prefHeight="180"
                                  wrapText="true"
                                  promptText="Enter the final diagnostic interpretation/results visible to patient and physician..."
                                  style="-fx-font-size:13;" />
                    </VBox>

                    <HBox spacing="12" alignment="CENTER_RIGHT">
                        <Region HBox.hgrow="ALWAYS"/>

                        <Button text="Publish To Shared Report Hub"
                                fx:id="publishButton"
                                onAction="#onPublishResults"
                                style="-fx-background-color:#0F766E; -fx-text-fill:white; -fx-font-size:13; -fx-font-weight:bold; -fx-background-radius:10; -fx-padding:10 24; -fx-cursor:hand;" />
                    </HBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>