<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="rakib.bcs430healthcareproject.DoctorPatientHistoryController"
            stylesheets="@app.css"
            style="-fx-background-color: #f8fafc;">

    <top>
        <VBox spacing="0">
            <HBox style="-fx-background-color: #0F766E; -fx-padding: 18 24; -fx-alignment: center-left; -fx-spacing: 15;">
                <Label text="HealthConnect"
                       style="-fx-text-fill: white; -fx-font-size: 22; -fx-font-weight: bold;" />

                <Region HBox.hgrow="ALWAYS" />

                <Button text="Back"
                        onAction="#handleBack"
                        style="-fx-background-color: white; -fx-text-fill: #0F766E; -fx-font-weight: bold; -fx-background-radius: 8;" />
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <content>
                <VBox spacing="18" style="-fx-padding: 24;">
                    <padding>
                        <Insets top="24" right="24" bottom="24" left="24"/>
                    </padding>

                    <VBox spacing="8"
                          style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 16; -fx-border-radius: 16; -fx-border-color: #dbeafe;">
                        <Label text="Patient Medical History"
                               style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #0F172A;" />
                        <Label fx:id="patientNameLabel"
                               style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #0F766E;" />
                        <Label fx:id="patientAgeGenderLabel"
                               style="-fx-font-size: 14; -fx-text-fill: #475569;" />
                        <Label fx:id="patientContactLabel"
                               style="-fx-font-size: 14; -fx-text-fill: #475569;" />
                    </VBox>

                    <VBox spacing="12"
                          style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 16; -fx-border-radius: 16; -fx-border-color: #dbeafe;">
                        <Label text="Medical Summary"
                               style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #0F172A;" />

                        <Label text="Allergies"
                               style="-fx-font-size: 14; -fx-font-weight: bold;" />
                        <TextArea fx:id="allergiesArea" prefRowCount="3"/>

                        <Label text="Current Medications"
                               style="-fx-font-size: 14; -fx-font-weight: bold;" />
                        <TextArea fx:id="medicationsArea" prefRowCount="3"/>

                        <Label text="Chronic Conditions"
                               style="-fx-font-size: 14; -fx-font-weight: bold;" />
                        <TextArea fx:id="chronicConditionsArea" prefRowCount="3"/>

                        <Label text="Medical History"
                               style="-fx-font-size: 14; -fx-font-weight: bold;" />
                        <TextArea fx:id="medicalHistoryArea" prefRowCount="5"/>
                    </VBox>

                    <VBox spacing="12"
                          style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 16; -fx-border-radius: 16; -fx-border-color: #dbeafe;">
                        <Label text="Additional Details"
                               style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #0F172A;" />

                        <HBox spacing="10">
                            <Label text="Blood Type:"
                                   style="-fx-font-weight: bold;" />
                            <Label fx:id="bloodTypeLabel" />
                        </HBox>

                        <Separator />

                        <HBox spacing="10">
                            <Label text="Vaccination Status:"
                                   style="-fx-font-weight: bold;" />
                            <Label fx:id="vaccinationStatusLabel" />
                        </HBox>

                        <Separator />

                        <HBox spacing="10">
                            <Label text="Height / Weight:"
                                   style="-fx-font-weight: bold;" />
                            <Label fx:id="heightWeightLabel" />
                        </HBox>

                        <Separator />

                        <HBox spacing="10">
                            <Label text="Emergency Contact:"
                                   style="-fx-font-weight: bold;" />
                            <Label fx:id="emergencyContactLabel" wrapText="true" />
                        </HBox>
                    </VBox>

                    <Label fx:id="statusLabel"
                           style="-fx-text-fill: #475569; -fx-font-size: 13;" />
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>