<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="rakib.bcs430healthcareproject.PharmacyForgotUsernameController"
            styleClass="root">

    <center>
        <StackPane>
            <VBox styleClass="card" maxWidth="460" spacing="16">
                <padding>
                    <Insets top="26" right="26" bottom="26" left="26"/>
                </padding>

                <VBox spacing="4">
                    <Label text="Forgot Username" styleClass="title"/>
                    <Label text="Enter the recovery email address associated with your pharmacy account."
                           wrapText="true"
                           styleClass="subtitle"/>
                </VBox>

                <VBox spacing="8">
                    <Label text="Recovery Email" styleClass="label"/>
                    <TextField fx:id="recoveryEmailField" promptText="recovery@example.com"/>
                </VBox>

                <Label fx:id="statusLabel" text="" managed="false" visible="false" styleClass="error"/>

                <Button text="Retrieve Username"
                        onAction="#onRetrieveUsername"
                        styleClass="primary-btn"
                        maxWidth="1.7976931348623157E308"/>

                <Button text="Back to Login"
                        onAction="#onBackToLogin"
                        styleClass="ghost-btn"
                        maxWidth="1.7976931348623157E308"/>
            </VBox>
        </StackPane>
    </center>

</BorderPane>