<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="650.0"
            prefWidth="1100.0"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="rakib.bcs430healthcareproject.HospitalMedicalRecordsController"
            stylesheets="@app.css"
            style="-fx-background-color: #F8FAFC;">

    <top>
        <VBox spacing="0">
            <HBox alignment="CENTER_LEFT"
                  spacing="15"
                  style="-fx-background-color: #0F766E; -fx-padding: 14 20;">

                <Label text="HealthConnect"
                       style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;" />

                <Region HBox.hgrow="ALWAYS" />

                <Button text="Refresh"
                        onAction="#onRefresh"
                        style="-fx-background-color: #14B8A6; -fx-text-fill: white; -fx-font-size: 12; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 14;" />

                <Button text="Back to Dashboard"
                        onAction="#onBack"
                        style="-fx-background-color: white; -fx-text-fill: #0F766E; -fx-font-size: 12; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 14;" />
            </HBox>

            <VBox spacing="4"
                  style="-fx-background-color: #134E4A; -fx-padding: 18 24;">
                <Label text="Hospital Medical Records"
                       style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;" />

                <Label fx:id="hospitalNameLabel"
                       text="Hospital"
                       style="-fx-text-fill: #CCFBF1; -fx-font-size: 13;" />
            </VBox>
        </VBox>
    </top>

    <center>
        <HBox spacing="16"
              style="-fx-padding: 16; -fx-background-color: #F8FAFC;">

            <VBox spacing="12"
                  HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 14; -fx-border-color: #D1FAE5; -fx-border-radius: 14;">

                <HBox alignment="CENTER_LEFT">
                    <Label text="Uploaded Diagnostic Reports"
                           style="-fx-text-fill: #0F766E; -fx-font-size: 17; -fx-font-weight: bold;" />

                    <Region HBox.hgrow="ALWAYS" />

                    <Label fx:id="statusLabel"
                           text="Loading records..."
                           style="-fx-text-fill: #475569; -fx-font-size: 12;" />
                </HBox>

                <TableView fx:id="reportsTable"
                           VBox.vgrow="ALWAYS"
                           prefHeight="500"
                           style="-fx-background-radius: 10; -fx-border-color: #E2E8F0; -fx-border-radius: 10;">

                    <columns>
                        <TableColumn fx:id="colDate" prefWidth="145" text="Uploaded" />
                        <TableColumn fx:id="colPatient" prefWidth="150" text="Patient" />
                        <TableColumn fx:id="colDoctor" prefWidth="150" text="Doctor" />
                        <TableColumn fx:id="colType" prefWidth="150" text="Report Type" />
                        <TableColumn fx:id="colTitle" prefWidth="220" text="Title" />
                    </columns>

                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </VBox>

            <VBox spacing="12"
                  prefWidth="380"
                  maxWidth="380"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 16; -fx-border-color: #D1FAE5; -fx-border-radius: 14;">

                <Label fx:id="selectedTitleLabel"
                       text="No report selected"
                       wrapText="true"
                       style="-fx-text-fill: #0F766E; -fx-font-size: 18; -fx-font-weight: bold;" />

                <Label fx:id="selectedPatientLabel"
                       text="Patient: -"
                       style="-fx-text-fill: #334155; -fx-font-size: 12; -fx-font-weight: bold;" />

                <Label fx:id="selectedDoctorLabel"
                       text="Doctor: -"
                       style="-fx-text-fill: #334155; -fx-font-size: 12; -fx-font-weight: bold;" />

                <Label fx:id="selectedDateLabel"
                       text="Uploaded: -"
                       style="-fx-text-fill: #64748B; -fx-font-size: 12;" />

                <Label text="Hospital Findings"
                       style="-fx-text-fill: #0F766E; -fx-font-size: 14; -fx-font-weight: bold;" />

                <TextArea fx:id="findingsArea"
                          editable="false"
                          wrapText="true"
                          prefHeight="160"
                          style="-fx-font-size: 13;" />

                <Label text="Diagnostic Results"
                       style="-fx-text-fill: #0F766E; -fx-font-size: 14; -fx-font-weight: bold;" />

                <TextArea fx:id="resultsArea"
                          editable="false"
                          wrapText="true"
                          VBox.vgrow="ALWAYS"
                          style="-fx-font-size: 13;" />
            </VBox>
        </HBox>
    </center>
</BorderPane>