<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="rakib.bcs430healthcareproject.PatientMessageController"
            stylesheets="@app.css">

    <top>
        <VBox spacing="0">
            <HBox style="-fx-background-color: #0F766E; -fx-padding: 18 24; -fx-alignment: center-left; -fx-spacing: 15;">
                <Button text="Back"
                        onAction="#onBack"
                        style="-fx-background-color: white; -fx-text-fill: #0F766E; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16;" />

                <Label text="Messages"
                       style="-fx-text-fill: white; -fx-font-size: 22; -fx-font-weight: bold;" />

                <Region HBox.hgrow="ALWAYS" />

                <Label fx:id="patientNameLabel"
                       style="-fx-text-fill: #CCFBF1; -fx-font-size: 14; -fx-font-weight: bold;" />
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="16" style="-fx-background-color: #F8FAFC; -fx-padding: 24;">

            <VBox spacing="8"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #D1FAE5; -fx-border-radius: 14; -fx-padding: 18;">
                <Label text="Select Doctor"
                       style="-fx-text-fill: #64748B; -fx-font-size: 12; -fx-font-weight: bold;" />

                <ComboBox fx:id="doctorComboBox"
                          onAction="#onDoctorSelected"
                          promptText="Choose a doctor conversation..."
                          style="-fx-background-radius: 10; -fx-border-radius: 10;" />

                <Label fx:id="doctorInfoLabel"
                       style="-fx-text-fill: #475569; -fx-font-size: 13;" />
            </VBox>

            <Label fx:id="statusLabel"
                   style="-fx-text-fill: #0F766E; -fx-font-size: 12; -fx-font-weight: bold;" />

            <ScrollPane fx:id="messagesScrollPane"
                        fitToWidth="true"
                        VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-border-color: transparent;">
                <content>
                    <VBox fx:id="messagesVBox"
                          spacing="10"
                          style="-fx-padding: 6;" />
                </content>
            </ScrollPane>

            <VBox spacing="10"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #D1FAE5; -fx-border-radius: 14; -fx-padding: 16;">
                <Label text="Write a Message"
                       style="-fx-text-fill: #0F172A; -fx-font-size: 15; -fx-font-weight: bold;" />

                <TextArea fx:id="messageInputArea"
                          promptText="Type your message to the doctor..."
                          wrapText="true"
                          prefRowCount="4"
                          style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-focus-color: #14B8A6; -fx-faint-focus-color: transparent;" />

                <HBox spacing="10" style="-fx-alignment: center-right;">
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="Clear"
                            onAction="#onClear"
                            style="-fx-background-color: #E2E8F0; -fx-text-fill: #0F172A; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16;" />
                    <Button fx:id="sendButton"
                            text="Send Message"
                            onAction="#onSendMessage"
                            style="-fx-background-color: #0EA5E9; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 18;" />
                </HBox>
            </VBox>

        </VBox>
    </center>
</BorderPane>