<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="rakib.bcs430healthcareproject.ForgotUsernameController"
            style="-fx-background-color: #E8F5E9;"> <top>
    <HBox style="-fx-background-color: #2E7D32; -fx-padding: 18 24; -fx-alignment: center-left;">
        <Label text="HealthConnect"
               style="-fx-text-fill: white; -fx-font-size: 22; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Account Recovery"
               style="-fx-text-fill: #C8E6C9; -fx-font-size: 14;"/>
    </HBox>
</top>

    <center>
        <StackPane alignment="CENTER" style="-fx-padding: 40;">
            <VBox spacing="20"
                  maxWidth="450"
                  style="-fx-background-color: white;
                         -fx-background-radius: 12;
                         -fx-padding: 36;
                         -fx-border-color: #C8E6C9;
                         -fx-border-radius: 12;
                         -fx-border-width: 1;">

                <effect>
                    <DropShadow color="#0000001A" radius="10" spread="0.0" width="20" height="20" offsetY="4"/>
                </effect>



                <VBox spacing="8">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Email Address"
                               style="-fx-font-size: 14; -fx-text-fill: #374151; -fx-font-weight: bold;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Hyperlink text="Forgot User?"
                                   onAction="#onSendUsername"
                                   style="-fx-font-size: 13; -fx-text-fill: #2E7D32; -fx-padding: 0; -fx-border-width: 0;"/>
                    </HBox>
                    <TextField fx:id="emailField"
                               promptText="name@example.com"
                               style="-fx-background-radius: 8; -fx-padding: 12; -fx-border-color: #A5D6A7; -fx-border-radius: 8; -fx-background-color: #F9FAFB;"/>
                </VBox>

                <Label fx:id="statusLabel"
                       text=""
                       managed="false"
                       visible="false"
                       style="-fx-font-size: 13; -fx-wrap-text: true;"/>

                <Button text="Send Username"
                        onAction="#onSendUsername"
                        maxWidth="Infinity"
                        style="-fx-background-color: #4CAF50;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-font-size: 15;
                               -fx-background-radius: 8;
                               -fx-padding: 12 16;
                               -fx-cursor: hand;"/>

                <HBox alignment="CENTER" style="-fx-padding: 16 0 0 0;">
                    <Hyperlink text="← Back to Login"
                               onAction="#onBackToLogin"
                               style="-fx-text-fill: #6B7280; -fx-font-size: 14; -fx-padding: 0; -fx-border-width: 0; -fx-underline: true;"/>
                </HBox>

            </VBox>
        </StackPane>
    </center>
</BorderPane>