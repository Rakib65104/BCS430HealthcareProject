<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="rakib.bcs430healthcareproject.ForgotPasswordController"
            style="-fx-background-color:#F4F9F9;">

    <top>
        <HBox style="-fx-background-color:#0F766E; -fx-padding:18 24; -fx-alignment:center-left;">
            <Label text="HealthConnect"
                   style="-fx-text-fill:white; -fx-font-size:22; -fx-font-weight:bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Account Recovery"
                   style="-fx-text-fill:#CCFBF1; -fx-font-size:14;"/>
        </HBox>
    </top>

    <center>
        <StackPane>
            <VBox spacing="16"
                  maxWidth="420"
                  style="-fx-background-color:white;
                         -fx-background-radius:12;
                         -fx-padding:28;
                         -fx-border-color:#E5E7EB;
                         -fx-border-radius:12;">

                <VBox spacing="4">
                    <Label text="Reset Password"
                           style="-fx-font-size:22; -fx-font-weight:bold; -fx-text-fill:#134E4A;"/>
                    <Label text="Enter your registered email address and we will send you a link to reset your password."
                           wrapText="true"
                           style="-fx-font-size:13; -fx-text-fill:#6B7280;"/>
                </VBox>

                <VBox spacing="6">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Email Address"
                               style="-fx-font-size:13; -fx-text-fill:#374151;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Hyperlink text="Forgot username?"
                                   onAction="#onForgotUsername"
                                   style="-fx-font-size:12; -fx-text-fill:#0F766E; -fx-padding:0; -fx-border-width:0;"/>
                    </HBox>
                    <TextField fx:id="emailField"
                               promptText="name@example.com"
                               style="-fx-background-radius:8; -fx-padding:8;"/>
                </VBox>

                <Label fx:id="statusLabel"
                       text=""
                       managed="false"
                       visible="false"
                       style="-fx-font-size:12; -fx-wrap-text:true;"/>

                <Button text="Send Reset Link"
                        onAction="#onSendResetLink"
                        maxWidth="Infinity"
                        style="-fx-background-color:#0F766E;
                               -fx-text-fill:white;
                               -fx-font-weight:bold;
                               -fx-background-radius:8;
                               -fx-padding:10 16;"/>

                <HBox alignment="CENTER" style="-fx-padding: 10 0 0 0;">
                    <Hyperlink text="← Back to Login"
                               onAction="#onBackToLogin"
                               style="-fx-text-fill:#6B7280; -fx-font-size:13; -fx-padding:0; -fx-border-width:0;"/>
                </HBox>

            </VBox>
        </StackPane>
    </center>
</BorderPane>