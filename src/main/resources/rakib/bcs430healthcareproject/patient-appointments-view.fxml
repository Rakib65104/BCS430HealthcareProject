<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="400.0" minWidth="600.0" prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="rakib.bcs430healthcareproject.PatientAppointmentsController">
    <children>
        <!-- Top Navigation Bar -->
        <HBox prefHeight="60.0" style="-fx-background-color: #2C3E50; -fx-padding: 10;">
            <children>
                <Button fx:id="backButton" mnemonicParsing="false" onAction="#onBack" style="-fx-padding: 8 15; -fx-font-size: 12; -fx-background-color: #34495E; -fx-text-fill: white; -fx-cursor: hand;" text="← Back" />
                <Label text="My Appointments" textFill="WHITE" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-padding: 0 15;" HBox.hgrow="ALWAYS" />
            </children>
        </HBox>

        <!-- Filter and Status Section -->
        <HBox spacing="10.0" style="-fx-padding: 15; -fx-background-color: #ECF0F1;" prefHeight="50.0">
            <children>
                <Label text="Filter:" style="-fx-font-size: 12; -fx-font-weight: bold;" />
                <ComboBox fx:id="filterComboBox" prefWidth="150.0" style="-fx-font-size: 12;" />
                <Label fx:id="statusLabel" text="Loading appointments..." style="-fx-text-fill: #27AE60; -fx-font-size: 12;" HBox.hgrow="ALWAYS" />
            </children>
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
        </HBox>

        <!-- Appointments List -->
        <ScrollPane fitToWidth="true" style="-fx-padding: 0; -fx-border-color: #BDC3C7;">
            <content>
                <VBox fx:id="appointmentsListVBox" spacing="5.0" style="-fx-padding: 15;">
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</VBox>
